{
  "output": {
    "style": "plain",
    "showLineNumbers": false,
    "removeComments": false
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "**/*.lock",
      "**/*.min.js",
      "**/*.min.css",
      "**/target/**",
      "**/.gradle/**",
      "**/__pycache__/**",
      "**/coverage/**",
      "**/*.png",
      "**/*.jpg",
      "**/*.jpeg",
      "**/*.gif",
      "**/*.ico",
      "**/*.woff",
      "**/*.woff2",
      "**/*.ttf",
      "**/*.eot",
      "**/*.pdf",
      "**/*.zip",
      "**/*.jar"
    ]
  },
  "security": {
    "enableSecurityCheck": false
  }
}
